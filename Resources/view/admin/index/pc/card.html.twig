{# @var item \BaksDev\Finances\Repository\AllFinance\FinanceResult #}

<tr class="vertical-middle">


    <td class="text-nowrap">
        {# Пользовательское меню #}
        {# {{ include(_self|replace({ "card.html.twig": "_usecase.html.twig" })) }} #}
    </td>

    <td>
        {{ item.getDate() }}
    </td>

    <td class="text-secondary">
        {{ item.getFirst() }}
    </td>

    <td>
        {{ item.getPaymentName() }}
    </td>

    <td>
        <a href="https://seller.ozon.ru/app/finances/accruals?tab=ACCRUALS_DETAILS&search={{ item.getNumber() }}"
           target="ozon" class="text-decoration-none">
            {{ item.getNumber() }}
        </a>
    </td>

    <td class="text-nowrap">
        {% if item.getOrderId() %}
            <button data-href='{{ path('orders-order:admin.detail', { id: item.getOrderId() }) }}'
                    data-id='{{ item.getOrderId() }}'
                    class="btn btn-sm btn-link fw-bolder mb-1 text-decoration-none product-name offcanvas-link"
            >
                {{ item.getOrderPosting() }}
            </button>
        {% endif %}
    </td>

    <td>
        {{ item.getComment() }}
    </td>

    <td>
        {% if item.getPrice().getRoundValue() > 0 %}
            {{ item.getPrice().value|number_format(2, '.', ' ') }}
        {% else %}
            <span class="badge rounded-pill text-bg-danger py-1 px-2">
                {{ item.getPrice().value|number_format(2, '.', ' ') }}
            </span>
        {% endif %}
    </td>

    <td class="text-nowrap text-center">
        <a href="https://seller.ozon.ru/app/finances/accruals?tab=ACCRUALS_DETAILS&search={{ item.getNumber() }}"
           target="ozon" class="text-decoration-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                 class="bi bi-info-circle-fill" viewBox="0 0 16 16">
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"/>
            </svg>
        </a>
    </td>
</tr>


